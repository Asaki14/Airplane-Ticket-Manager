{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "tests", "next-env.d.ts", "vitest.config.ts"],
  "exclude": ["node_modules"]
}
